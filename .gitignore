# ============================================================
# Eye Blink Detection - .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Dataset (too large for git) ---
dataset/raw_eyes/
dataset/train/
dataset/test/
data/raw_videos/

# --- Trained Models (large binary files) ---
models/*.pkl
models/*.dat
models/*.png

# --- Logs & temp ---
*.log
*.tmp

# --- Jupyter ---
.ipynb_checkpoints/
